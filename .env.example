# Shared
APP_ORIGIN=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_STORAGE_BUCKET=message-attachments

# Frontend
NEXT_PUBLIC_REALTIME_WS_URL=ws://localhost:4000/socket
NEXT_PUBLIC_ANALYTICS_URL=http://localhost:8010
NEXT_PUBLIC_ANALYTICS_API_KEY=dev-analytics-key
NEXT_PUBLIC_MAX_UPLOAD_MB=25

# Phoenix realtime service
PHX_HOST=localhost
PORT=4000
SECRET_KEY_BASE=replace-with-mix-phx.gen.secret
DATABASE_URL=ecto://postgres:postgres@localhost/relaychat_realtime_dev

# Analytics service
ANALYTICS_API_KEY=replace-with-internal-token
ANALYTICS_ALLOWED_ORIGINS=http://localhost:3000
